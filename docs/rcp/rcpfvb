frequence:"Hebdomadaire",
lieu:"Service d'imagerie"
}
],

"Pays de la Loire":[
{
centre:"CHU Nantes",
reunion:"RCP foie et voies biliaires",
jour:"Mercredi",
horaire:"13h30-16h",
frequence:"Hebdomadaire",
lieu:"CHU Nantes"
},
{
centre:"CHU Angers",
reunion:"RCP des tumeurs primitives hépatiques",
jour:"Vendredi",
horaire:"15h",
frequence:"Hebdomadaire",
lieu:"CHU Angers"
}
],

"Normandie":[
{
centre:"CHU Caen",
reunion:"RCP Tumeurs primitives du Foie",
jour:"Lundi",
horaire:"16h30-19h",
frequence:"Hebdomadaire",
lieu:"Hôpital Côte de la Nacre"
}
],

"Ile-de-France":[
{
centre:"Hôpital Beaujon AP-HP",
reunion:"RCP Tumeurs hépatiques",
jour:"Lundi",
horaire:"14h-18h",
frequence:"Hebdomadaire",
lieu:"Salle de staff radiologie"
},
{
