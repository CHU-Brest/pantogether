<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Carte Interactive RCP France + DROM</title>

<style>
body{
    margin:0;
    font-family:Segoe UI,Arial,sans-serif;
    background:#f4f6f9;
    color:#1f2937;
}

header{
    padding:25px;
    background:white;
    box-shadow:0 2px 8px rgba(0,0,0,.05);
}

h1{
    margin:0;
    color:crimson;
}

.subtitle{
    margin-top:8px;
    color:#555;
}

.layout{
    display:flex;
    height:calc(100vh - 110px);
}

#mapContainer{
    flex:1;
    background:#eef2f7;
    position:relative;
    overflow:auto;
}

svg{
    width:100%;
    height:100%;
}

.region{
    fill:#cbd5e1;
    stroke:white;
    stroke-width:2;
    cursor:pointer;
    transition:.2s;
}

.region:hover{
    fill:#2563eb;
}

.region.active{
    fill:#dc2626;
}

#regionPanel{
    width:430px;
    background:white;
    overflow:auto;
    border-left:1px solid #e5e7eb;
    padding:20px;
}

.region-title{
    font-size:24px;
    margin-bottom:15px;
    color:#111827;
}

.card{
    background:#f9fafb;
    border:1px solid #e5e7eb;
    border-radius:14px;
    padding:16px;
    margin-bottom:16px;
    transition:.2s;
}

.card:hover{
    transform:translateY(-2px);
    box-shadow:0 4px 12px rgba(0,0,0,.06);
}

.card h3{
    margin:0 0 8px 0;
    color:#111827;
}

.badge{
    display:inline-block;
    padding:4px 10px;
    border-radius:999px;
    background:#dbeafe;
    color:#1d4ed8;
    font-size:12px;
    margin-bottom:10px;
}

.info{
    font-size:14px;
    margin:6px 0;
}

details{
    margin-top:10px;
}

summary{
    cursor:pointer;
    font-weight:600;
}

.empty{
    color:#6b7280;
    padding:20px;
}

.drom{
    fill:#94a3b8;
}

.legend{
    position:absolute;
    bottom:20px;
    left:20px;
    background:white;
    padding:10px 14px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
    font-size:13px;
}

.dot{
    width:12px;
    height:12px;
    display:inline-block;
    border-radius:50%;
    margin-right:6px;
}

@media(max-width:1000px){
    .layout{
        flex-direction:column;
        height:auto;
    }

    #regionPanel{
        width:100%;
        border-left:none;
        border-top:1px solid #e5e7eb;
    }

    #mapContainer{
        height:65vh;
    }
}
</style>
</head>

<body>

<header>
    <h1>Foie et Voies Biliaires</h1>
    <div class="subtitle">
        Carte interactive des RCP en France métropolitaine et DROM
    </div>
</header>

<div class="layout">

<div id="mapContainer">

<!-- ===================== CARTE SVG ===================== -->

<svg viewBox="0 0 1000 900">

    <!-- Bretagne -->
    <path class="region" id="Bretagne"
        d="M120 260 L190 220 L250 240 L260 300 L210 340 L150 330 L110 290 Z"/>

    <!-- Normandie -->
    <path class="region" id="Normandie"
        d="M240 180 L340 170 L380 230 L330 280 L250 260 Z"/>

    <!-- Hauts-de-France -->
    <path class="region" id="Hauts-de-France"
        d="M430 80 L530 70 L580 130 L520 190 L430 160 Z"/>

    <!-- Grand Est -->
    <path class="region" id="Grand-Est"
        d="M600 130 L720 120 L780 250 L730 360 L620 340 L570 230 Z"/>

    <!-- Pays de la Loire -->
    <path class="region" id="Pays de la Loire"
        d="M220 340 L320 330 L360 400 L300 470 L210 430 Z"/>

    <!-- Centre-Val-de-Loire -->
    <path class="region" id="Centre-Val-de-Loire"
        d="M380 320 L500 320 L530 400 L450 470 L350 430 Z"/>

    <!-- Ile-de-France -->
    <circle class="region" id="Ile-de-France" cx="520" cy="280" r="35"/>

    <!-- Bourgogne -->
    <path class="region" id="Bourgogne-Franche-Comté"
        d="M560 330 L670 330 L700 430 L610 500 L540 450 Z"/>

    <!-- Nouvelle-Aquitaine -->
    <path class="region" id="Nouvelle-Aquitaine"
        d="M180 500 L360 500 L400 700 L260 820 L130 740 L120 590 Z"/>

    <!-- Auvergne Rhône Alpes -->
    <path class="region" id="Auvergne-Rhône-Alpes"
        d="M620 500 L760 470 L820 640 L700 770 L570 700 Z"/>

    <!-- Occitanie -->
    <path class="region" id="Occitanie"
        d="M410 650 L560 650 L610 820 L450 860 L320 790 Z"/>

    <!-- PACA -->
    <path class="region" id="Provence-Alpes-Côte-d'Azur"
        d="M760 700 L900 720 L930 820 L790 850 L720 780 Z"/>

    <!-- Guadeloupe -->
    <circle class="region drom" id="Guadeloupe" cx="850" cy="180" r="18"/>

    <!-- Labels -->
    <text x="150" y="285" font-size="16">Bretagne</text>
    <text x="270" y="220" font-size="16">Normandie</text>
    <text x="440" y="130" font-size="16">Hauts-de-France</text>
    <text x="640" y="240" font-size="16">Grand Est</text>
    <text x="240" y="400" font-size="16">Pays de la Loire</text>
    <text x="390" y="390" font-size="16">Centre</text>
    <text x="500" y="285" font-size="14">IDF</text>
    <text x="560" y="420" font-size="14">BFC</text>
    <text x="190" y="640" font-size="16">Nouvelle-Aquitaine</text>
    <text x="610" y="620" font-size="16">AURA</text>
    <text x="430" y="760" font-size="16">Occitanie</text>
    <text x="780" y="790" font-size="16">PACA</text>
    <text x="820" y="150" font-size="14">Guadeloupe</text>

</svg>

<div class="legend">
    <div><span class="dot" style="background:#cbd5e1"></span> Région</div>
    <div><span class="dot" style="background:#dc2626"></span> Région sélectionnée</div>
</div>

</div>

<!-- ===================== PANNEAU ===================== -->

<div id="regionPanel">

<div class="empty">
    Cliquez sur une région de la carte pour afficher les RCP.
</div>

</div>

</div>

<script>

const rcpData = {

"Bretagne":[
{
